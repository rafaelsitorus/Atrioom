# Supabase — ambil dari dashboard project Supabase Anda (https://app.supabase.com)
# Public (aman di-expose ke browser)
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_ANON_KEY"

# Server-only (JANGAN commit nilai asli)
SUPABASE_SERVICE_ROLE_KEY="YOUR_SERVICE_ROLE_KEY"

# API internal (opsional, default http://localhost:4000)
INTERNAL_API_BASE_URL="http://localhost:4000"